  </joint>
  <joint name="left_hand_mid_joint2" type="revolute">
    <parent link="left_hand_mid_link1"/><child link="left_hand_mid_link2"/><origin xyz="0 0 0.0558" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>
  <joint name="left_hand_mid_joint3" type="fixed">
    <parent link="left_hand_mid_link2"/><child link="left_hand_mid_tip"/><origin xyz="0 0 0.0425" rpy="0 0 0"/>
  </joint>
  <joint name="left_hand_ring_joint1" type="revolute">
