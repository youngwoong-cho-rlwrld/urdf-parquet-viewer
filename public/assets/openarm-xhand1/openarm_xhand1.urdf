<?xml version="1.0"?>
<!--
  Kinematic-only OpenArm v2 + dual XHand1 description for the browser viewer.
  Arm origins/axes are from enactic/openarm_description. XHand1 origins/axes
  match the authored left/right RobotEra STAR1 URDFs after a rigid re-expression
  into the browser skeleton's hand frames. The fixed wrist rotations below undo
  that re-expression, so each physical XHand source frame is identity-clocked
  to its OpenArm joint-7 frame. The viewer intentionally ignores meshes.
-->
<robot name="openarm_xhand1">
  <link name="world"/>
  <link name="openarm_body_link0"/>
  <link name="openarm_head_pitch_link"/>
  <link name="openarm_head_yaw_link"/>

  <link name="openarm_left_base_link"/>
  <link name="openarm_left_link1"/>
  <link name="openarm_left_link2"/>
  <link name="openarm_left_link3"/>
  <link name="openarm_left_link4"/>
  <link name="openarm_left_link5"/>
  <link name="openarm_left_link6"/>
  <link name="openarm_left_wrist_link"/>
  <link name="left_hand_link"/>
  <link name="left_hand_thumb_bend_link"/>
  <link name="left_hand_thumb_rota_link1"/>
  <link name="left_hand_thumb_rota_link2"/>
  <link name="left_hand_thumb_rota_tip"/>
  <link name="left_hand_index_bend_link"/>
  <link name="left_hand_index_rota_link1"/>
  <link name="left_hand_index_rota_link2"/>
  <link name="left_hand_index_tip"/>
  <link name="left_hand_mid_link1"/>
  <link name="left_hand_mid_link2"/>
  <link name="left_hand_mid_tip"/>
  <link name="left_hand_ring_link1"/>
  <link name="left_hand_ring_link2"/>
  <link name="left_hand_ring_tip"/>
  <link name="left_hand_pinky_link1"/>
  <link name="left_hand_pinky_link2"/>
  <link name="left_hand_pinky_tip"/>

  <link name="openarm_right_base_link"/>
  <link name="openarm_right_link1"/>
  <link name="openarm_right_link2"/>
  <link name="openarm_right_link3"/>
  <link name="openarm_right_link4"/>
  <link name="openarm_right_link5"/>
  <link name="openarm_right_link6"/>
  <link name="openarm_right_wrist_link"/>
  <link name="right_hand_link"/>
  <link name="right_hand_thumb_bend_link"/>
  <link name="right_hand_thumb_rota_link1"/>
  <link name="right_hand_thumb_rota_link2"/>
  <link name="right_hand_thumb_rota_tip"/>
  <link name="right_hand_index_bend_link"/>
  <link name="right_hand_index_rota_link1"/>
  <link name="right_hand_index_rota_link2"/>
  <link name="right_hand_index_tip"/>
  <link name="right_hand_mid_link1"/>
  <link name="right_hand_mid_link2"/>
  <link name="right_hand_mid_tip"/>
  <link name="right_hand_ring_link1"/>
  <link name="right_hand_ring_link2"/>
  <link name="right_hand_ring_tip"/>
  <link name="right_hand_pinky_link1"/>
  <link name="right_hand_pinky_link2"/>
  <link name="right_hand_pinky_tip"/>

  <joint name="openarm_body_mount" type="fixed">
    <parent link="world"/><child link="openarm_body_link0"/><origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <joint name="openarm_head_pitch" type="revolute">
    <parent link="openarm_body_link0"/><child link="openarm_head_pitch_link"/>
    <origin xyz="0 0 0.82" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>
  <joint name="openarm_head_yaw" type="revolute">
    <parent link="openarm_head_pitch_link"/><child link="openarm_head_yaw_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/><axis xyz="0 0 1"/>
  </joint>

  <joint name="openarm_left_mount" type="fixed">
    <parent link="openarm_body_link0"/><child link="openarm_left_base_link"/><origin xyz="0 0.031 0.698" rpy="0 0 0"/>
  </joint>
  <joint name="openarm_left_joint1" type="revolute">
    <parent link="openarm_left_base_link"/><child link="openarm_left_link1"/><origin xyz="0 0.0625 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>
