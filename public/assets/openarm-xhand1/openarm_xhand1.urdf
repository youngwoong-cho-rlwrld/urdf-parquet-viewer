    <parent link="openarm_left_link6"/><child link="openarm_left_wrist_link"/><origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="1 0 0"/>
  </joint>
  <joint name="left_xhand_mount" type="fixed">
    <parent link="openarm_left_wrist_link"/><child link="left_hand_link"/><origin xyz="0 0 -0.03" rpy="3.141592653589793 0 -1.570796326794897"/>
  </joint>
  <joint name="left_hand_thumb_bend_joint" type="revolute">
    <parent link="left_hand_link"/><child link="left_hand_thumb_bend_link"/><origin xyz="0.0095 -0.0228 0.0305" rpy="0 0 0"/><axis xyz="0 0 1"/>
  </joint>
  <joint name="left_hand_thumb_rota_joint1" type="revolute">
    <parent link="left_hand_thumb_bend_link"/><child link="left_hand_thumb_rota_link1"/><origin xyz="0.0083177 -0.028599 -0.00178" rpy="0 0.2618 0.0407"/><axis xyz="-1 0 0"/>
  </joint>
  <joint name="left_hand_thumb_rota_joint2" type="revolute">
